{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "${sourceDir}/vendor/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "x64-linux",
      "displayName": "x64 Multi-Config",
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "x86-linux",
      "displayName": "x86 Multi-Config",
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-linux"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "x64-win-clion",
      "displayName": "x64 Multi-Config",
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "x86-win-clion",
      "displayName": "x86 Multi-Config",
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-mingw-dynamic"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "x64-win-vs",
      "displayName": "x64 MSVC Multi-Config",
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "x86-win-vs",
      "displayName": "x86 MSVC Multi-Config",
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-windows"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "x64-win-standalone",
      "displayName": "x64 Multi-Config",
      "inherits": "base",
      "hidden": true,
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
      }
    },
    {
      "name": "x86-win-standalone",
      "displayName": "x86 Multi-Config",
      "inherits": "base",
      "hidden": true,
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-mingw-dynamic"
      }
    }
  ],

  "buildPresets": [
    { "name": "x64-debug", "configurePreset": "x64-linux", "configuration": "Debug" },
    { "name": "x64-release", "configurePreset": "x64-linux", "configuration": "Release" },
    { "name": "x86-debug", "configurePreset": "x86-linux", "configuration": "Debug" },
    { "name": "x86-release", "configurePreset": "x86-linux", "configuration": "Release" },

    { "name": "x64-win-debug", "configurePreset": "x64-win-clion", "configuration": "Debug" },
    { "name": "x64-win-release", "configurePreset": "x64-win-clion", "configuration": "Release" },
    { "name": "x86-win-debug", "configurePreset": "x86-win-clion", "configuration": "Debug" },
    { "name": "x86-win-release", "configurePreset": "x86-win-clion", "configuration": "Release" },

    { "name": "x64-msvc-debug", "configurePreset": "x64-win-vs", "configuration": "Debug" },
    { "name": "x64-msvc-release", "configurePreset": "x64-win-vs", "configuration": "Release" },
    { "name": "x86-msvc-debug", "configurePreset": "x86-win-vs", "configuration": "Debug" },
    { "name": "x86-msvc-release", "configurePreset": "x86-win-vs", "configuration": "Release" },

    { "name": "x64-standalone-debug", "configurePreset": "x64-win-standalone", "configuration": "Debug", "hidden": true },
    { "name": "x64-standalone-release", "configurePreset": "x64-win-standalone", "configuration": "Release", "hidden": true },
    { "name": "x86-standalone-debug", "configurePreset": "x86-win-standalone", "configuration": "Debug", "hidden": true },
    { "name": "x86-standalone-release", "configurePreset": "x86-win-standalone", "configuration": "Release", "hidden": true }
  ]
}