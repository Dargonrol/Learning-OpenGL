{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "${sourceDir}/vendor/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "x64",
      "displayName": "x64 Linux Multi-Config",
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "x64",
      "displayName": "x64 Windows (CLion MinGW)",
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
      },
      "condition": {
        "and": [
          { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
          { "type": "inList", "string": "true", "list": [ "${env.CLION_IDE}" ] }
        ]
      }
    },
    {
      "name": "x64",
      "displayName": "x64 Windows (Portable MinGW)",
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
      },
      "condition": {
        "and": [
          { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
          { "type": "notInList", "string": "true", "list": [ "${env.CLION_IDE}" ] }
        ]
      }
    },
    {
      "name": "x86",
      "displayName": "x86 Linux Multi-Config",
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-linux"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "x86",
      "displayName": "x86 Windows (CLion MinGW)",
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-mingw-dynamic"
      },
      "condition": {
        "and": [
          { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
          { "type": "inList", "string": "true", "list": [ "${env.CLION_IDE}" ] }
        ]
      }
    },
    {
      "name": "x86",
      "displayName": "x86 Windows (Portable MinGW)",
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-mingw-dynamic"
      },
      "condition": {
        "and": [
          { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
          { "type": "notInList", "string": "true", "list": [ "${env.CLION_IDE}" ] }
        ]
      }
    }
  ],

  "buildPresets": [
    { "name": "x64-debug", "configurePreset": "x64", "configuration": "Debug" },
    { "name": "x64-release", "configurePreset": "x64", "configuration": "Release" },
    { "name": "x86-debug", "configurePreset": "x86", "configuration": "Debug" },
    { "name": "x86-release", "configurePreset": "x86", "configuration": "Release" }
  ]
}