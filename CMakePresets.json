{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "${sourceDir}/vendor/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "x64",
      "displayName": "x64 Multi-Config",
      "inherits": "base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "x64-win",
      "displayName": "x64 Windows Multi-Config",
      "inherits": "base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "x86",
      "displayName": "x86 Multi-Config",
      "inherits": "base",
      "architecture": {
        "value": "x86",
        "strategy": "external"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-linux"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "x86-win",
      "displayName": "x86 Windows Multi-Config",
      "inherits": "base",
      "architecture": {
        "value": "x86",
        "strategy": "external"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-windows"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    { "name": "x64-debug", "configurePreset": "x64", "configuration": "Debug" },
    { "name": "x64-release", "configurePreset": "x64", "configuration": "Release" },
    { "name": "x86-debug", "configurePreset": "x86", "configuration": "Debug" },
    { "name": "x86-release", "configurePreset": "x86", "configuration": "Release" },

    { "name": "x64-win-debug", "configurePreset": "x64-win", "configuration": "Debug" },
    { "name": "x64-win-release", "configurePreset": "x64-win", "configuration": "Release" },
    { "name": "x86-win-debug", "configurePreset": "x86-win", "configuration": "Debug" },
    { "name": "x86-win-release", "configurePreset": "x86-win", "configuration": "Release" }
  ]
}